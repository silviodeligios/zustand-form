{
  "name": "zform",
  "version": "0.1.0",
  "description": "A React form hook powered by Zustand",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./src": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "demo": "cd demo && npx vite",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "form",
    "zustand",
    "hooks"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "zod": ">=4.0.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.1",
    "zod": "^4.0.0",
    "zustand": "^4.5.0"
  },
  "sideEffects": false
}
